  },
  // Party Hat Green (Current location is the mine, and the mine level < 40)
  "(H)59": {
    "Speed": 1,
    "LuckLevel": 1,
    "Condition": "SummerFleur.BetterHats.MINE_LEVEL_RANGE Here 1 39",
    "Trigger": "LocationChanged",
    "ConditionDescription": "i18n:condition.PartyHatGreen"
  },
  // Party Hat Blue (Current location is the mine, and the mine level is 40~79)
  "(H)58": {
    "Speed": 1,
    "LuckLevel": 1,
    "Condition": "SummerFleur.BetterHats.MINE_LEVEL_RANGE Here 40 79",
    "Trigger": "LocationChanged",
    "ConditionDescription": "i18n:condition.PartyHatBlue"
  },
  // Party Hat Red (Current location is the mine, and the mine level >= 80)
  "(H)57": {
    "Speed": 1,
    "LuckLevel": 1,
    "Condition": "SummerFleur.BetterHats.MINE_LEVEL_RANGE Here 80",
    "Trigger": "LocationChanged",
    "ConditionDescription": "i18n:condition.PartyHatRed"
  },
  // Logo Cap
  "(H)45": {
    "FishingLevel": 1,
    "LuckLevel": 1,
    "Condition": "SummerFleur.BetterHats.MINE_LEVEL Here 20 60 100",
    "Trigger": "LocationChanged",
    "Dynamic": true,
    "Description": "i18n:description.LogoCap",
    "ConditionDescription": "i18n:condition.LogoCap",
    "ModifierDescription": "i18n:modifier.LogoCap"
  },
  // Space Helmet (Current location is the difficult mine)
  "(H)SpaceHelmet": {
    "AttackMultiplier": 0.1,
    "Defense": 2,
    "Speed": 0.5,
    "Condition": "$CustomCondition",
    "Trigger": "LocationChanged",
    "Description": "i18n:description.SpaceHelmet",
    "ConditionDescription": "i18n:condition.SpaceHelmet",
    "ModifierDescription": "i18n:modifier.SpaceHelmet"
  },
  // Sou'wester (Current weather is stormy)
  "(H)28": {
    "FishingLevel": 2,
    "Condition": "LOCATION_IS_OUTDOORS Here, WEATHER Here Rain Storm GreenRain",
    "Trigger": "LocationChanged",
    "ConditionDescription": "i18n:condition.Souwester",
    "ModifierDescription": "i18n:modifier.Souwester"
  },
  // Blobfish Mask (Current location is the submarine)
  "(H)56": {
    "FishingLevel": 2,
    "Condition": "LOCATION_NAME Here Submarine",
    "Trigger": "LocationChanged",
    "ConditionDescription": "i18n:condition.BlobfishMask"
  },
