  /**** 
    Belows are hat data with some extra conditions or some special
    effects. You can directly edit them, but they must match the 
    game's query or trigger action format; otherwise the effect will
    not work. 

    This mod defines some other query methods and trigger actions, 
    these methods and actions starts with "SummerFleur.BetterHats".
    And you can see their implementation in the `GameExtensions.cs`.
   ****/
  // Daisy (Current season is spring)
  "(H)29": {
    "Speed": 0.5,
    "LuckLevel": 1,
    "Condition": "SEASON Spring",
    "Trigger": "DayStarted",
    "ConditionDescription": "i18n:condition.Spring"
  },
  // Sunglasses (Current season is summer)
  "(H)88": {
    "Speed": 0.5,
    "LuckLevel": 1,
    "Condition": "SEASON Summer",
    "Trigger": "DayStarted",
    "ConditionDescription": "i18n:condition.Summer"
  },
  // Watermelon Band (Current season is summer)
  "(H)30": {
    "Speed": 0.5,
    "LuckLevel": 1,
    "Condition": "SEASON Summer",
    "Trigger": "DayStarted",
    "ConditionDescription": "i18n:condition.Summer"
  },
  // Fedora (Current season is fall)
  "(H)19": {
    "Speed": 0.5,
    "LuckLevel": 1,
    "Condition": "SEASON Fall",
    "Trigger": "DayStarted",
    "ConditionDescription": "i18n:condition.Fall"
  },
  // Earmuffs (Current season is winter)
  "(H)11": {
    "Speed": 0.5,
    "LuckLevel": 1,
    "Condition": "SEASON Winter",
    "Trigger": "DayStarted",
    "ConditionDescription": "i18n:condition.Winter"
  },
  // Butterfly Bow (Current date is spring 15~18)
  "(H)14": {
    "ForagingLevel": 1,
    "Condition": "LOCATION_SEASON Here Spring, SEASON_DAY Spring 15 Spring 16 Spring 17 Spring 18",
    "Trigger": "DayStarted",
    "Description": "i18n:description.ButterflyBow",
    "ConditionDescription": "i18n:condition.ButterflyBow"
  },
  // Bucket Hat (During the Trout Derby)
  "(H)BucketHat": {
    "FishingLevel": 2,
    "MaxStamina": 50,
    "Condition": "SEASON_DAY Summer 20 Summer 21",
    "Trigger": "DayStarted",
    "Description": "i18n:description.BucketHat",
    "ConditionDescription": "i18n:condition.BucketHat"
  },
  // Pumpkin Mask (Current date is fall 8~11)
  "(H)48": {
